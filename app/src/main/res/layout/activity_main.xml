<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#050505">
    <LinearLayout android:orientation="vertical" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:text="SPACE WEATHER (NOAA)" android:textColor="#FFD700" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/space_data" android:text="Bz: -- | Kp: -- | Wind: --" android:textColor="#FFFFFF" android:textSize="18sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#222222" android:layout_marginVertical="10dp"/>
        <TextView android:text="ATMOSPHERICS & RESONANCE" android:textColor="#00FF00" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/env_data" android:text="Baro: -- | Schumann: -- | Hemi: --" android:textColor="#FFFFFF" android:textSize="18sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#222222" android:layout_marginVertical="10dp"/>
        <TextView android:text="BIOMETRICS (Y007)" android:textColor="#00FFFF" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/bio_data" android:text="BP: --/-- | HR: -- BPM" android:textColor="#FFFFFF" android:textSize="22sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/brain_status" android:text="BRAIN: Analyzing Patterns..." android:background="#111100" android:textColor="#FFFF00" android:padding="10dp" android:layout_marginTop="20dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <RadioGroup android:id="@+id/report_type_group" android:layout_width="match_parent" android:layout_height="wrap_content"> 
            <RadioButton android:id="@+id/radio_general" android:text="General Health Report" android:textColor="#FFFFFF"/> 
            <RadioButton android:id="@+id/radio_flare" android:visibility="gone" android:text="Solar Symptom Flare Report" android:textColor="#FFFFFF"/> 
            <RadioButton android:id="@+id/radio_predict" android:visibility="gone" android:text="Solar Flare Prediction Report" android:textColor="#FFFFFF"/> 
        </RadioGroup>
        <Button android:id="@+id/btn_report" android:text="GENERATE AI CLINICAL REPORT" android:layout_marginTop="20dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>
