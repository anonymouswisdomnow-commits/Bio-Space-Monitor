<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBg">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🛰 SPACE WEATHER" android:textColor="@color/colorText"
            android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Real-time ANS impact indicators"
            android:textColor="@color/colorMuted" android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <!-- Kp Index -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Kp Index" android:textColor="@color/colorText"
                        android:textSize="16sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Geomagnetic storm level" android:textColor="@color/colorMuted"
                        android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ANS: Arrhythmia risk above 5"
                        android:textColor="@color/colorWarn" android:textSize="10sp"/>
                </LinearLayout>
                <TextView android:id="@+id/tv_kp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textColor="@color/colorAccent"
                    android:textSize="36sp" android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bz Component -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="IMF Bz Component" android:textColor="@color/colorText"
                        android:textSize="16sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Southward = magnetic shield open"
                        android:textColor="@color/colorMuted" android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ANS: Primary dysautonomia flare trigger"
                        android:textColor="@color/colorAlert" android:textSize="10sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_bz"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textColor="@color/colorAccent"
                        android:textSize="36sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_bz_direction"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="nT" android:textColor="@color/colorMuted" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Solar Wind Speed -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Solar Wind Speed" android:textColor="@color/colorText"
                        android:textSize="16sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="High-speed streams from coronal holes"
                        android:textColor="@color/colorMuted" android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ANS: Fatigue and elevated resting HR above 500"
                        android:textColor="@color/colorWarn" android:textSize="10sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_wind_speed"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textColor="@color/colorAccent"
                        android:textSize="28sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="km/s" android:textColor="@color/colorMuted" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Solar Wind Density -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Solar Wind Density" android:textColor="@color/colorText"
                        android:textSize="16sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Dynamic pressure on magnetic shield"
                        android:textColor="@color/colorMuted" android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ANS: Anxiety and sympathetic dominance above 10"
                        android:textColor="@color/colorWarn" android:textSize="10sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_wind_density"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textColor="@color/colorAccent"
                        android:textSize="28sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="p/cm³" android:textColor="@color/colorMuted" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Solar Flux -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Solar Flux F10.7" android:textColor="@color/colorText"
                        android:textSize="16sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Radio emissions proxy for solar activity"
                        android:textColor="@color/colorMuted" android:textSize="11sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ANS: General solar activity baseline"
                        android:textColor="@color/colorSpace" android:textSize="10sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_solar_flux"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textColor="@color/colorAccent"
                        android:textSize="28sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="sfu" android:textColor="@color/colorMuted" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Space Weather Summary -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/colorCard2" app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ANS RISK SUMMARY" android:textColor="@color/colorMuted"
                    android:textSize="11sp" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tv_space_summary"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Fetching space weather data..."
                    android:textColor="@color/colorText" android:textSize="13sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView android:id="@+id/tv_space_updated"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Data from NOAA Space Weather Prediction Center"
            android:textColor="@color/colorMuted" android:textSize="10sp"
            android:layout_gravity="center_horizontal"/>
    </LinearLayout>
</ScrollView>
