<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="8dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tv_log_bp" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="--/-- mmHg"
                android:textColor="@color/colorText" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tv_log_hr" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="HR: -- | SpO2: --%"
                android:textColor="@color/colorMuted" android:textSize="12sp"/>
            <TextView android:id="@+id/tv_log_space" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text=""
                android:textColor="@color/colorSpace" android:textSize="10sp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="end">
            <TextView android:id="@+id/tv_log_time" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/colorMuted"
                android:textSize="10sp"/>
            <TextView android:id="@+id/tv_log_status" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="●"
                android:textSize="16sp" android:textColor="@color/colorOk"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
