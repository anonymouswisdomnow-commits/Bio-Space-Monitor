<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BioSpace Monitor" android:textColor="@color/colorText"
                    android:textSize="20sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tv_connection_status"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚫ Scanning..." android:textColor="@color/colorMuted" android:textSize="11sp"/>
            </LinearLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_connect"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Connect" android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>

        <!-- BP Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="❤  BLOOD PRESSURE" android:textColor="@color/colorMuted"
                    android:textSize="11sp" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tv_bp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--/--" android:textColor="@color/colorText"
                    android:textSize="52sp" android:textStyle="bold"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:id="@+id/tv_bp_mmhg"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="mmHg"
                        android:textColor="@color/colorMuted" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_bp_category"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Awaiting reading" android:textColor="@color/colorAccent"
                        android:textSize="12sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 2x3 Metric Grid -->
        <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:columnCount="2" android:layout_marginBottom="10dp">

            <!-- HR Tile -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tv_hr" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="28sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="bpm" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="❤ Heart Rate" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SpO2 Tile -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tv_spo2" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="28sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="%" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🫁 SpO2" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Steps Tile -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tv_steps" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="28sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="steps" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👟 Activity" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Calories Tile -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tv_calories" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="28sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="kcal" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔥 Calories" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sleep Tile -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tv_sleep" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="28sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="hrs" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💤 Sleep" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Temp Tile -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tv_temp" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="28sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="°F" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌡 Temp" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>

        <!-- ANS Alert Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_ans_alert"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" android:visibility="gone"
            app:cardBackgroundColor="#1A1500"
            app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚠ ANS CORRELATION DETECTED"
                    android:textColor="@color/colorWarn" android:textSize="11sp" android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tv_ans_alert"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/colorText" android:textSize="12sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Last Update -->
        <TextView android:id="@+id/tv_last_update"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Press watch button to take a reading"
            android:textColor="@color/colorMuted" android:textSize="11sp"
            android:layout_gravity="center_horizontal" android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>
