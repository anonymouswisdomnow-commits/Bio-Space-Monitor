<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BioSpace Monitor"
                    android:textColor="@color/colorText"
                    android:textSize="20sp" android:textStyle="bold"/>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <View android:layout_width="8dp" android:layout_height="8dp"
                        android:background="@drawable/pulse_dot" android:layout_marginEnd="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:id="@+id/tv_last_update"
                        android:text="Live Monitoring"
                        android:textColor="@color/colorMuted" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_refresh"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Refresh"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_rotate"
                style="@style/Widget.MaterialComponents.Button"/>
        </LinearLayout>

        <!-- BP Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_bp"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="12dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/colorAccent">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="❤️  BLOOD PRESSURE"
                        android:textColor="@color/colorMuted" android:textSize="11sp"
                        android:letterSpacing="0.1"/>
                    <TextView android:id="@+id/tv_cal_badge"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✓ Calibrated"
                        android:textColor="@color/colorOk" android:textSize="11sp"
                        android:visibility="gone"/>
                </LinearLayout>

                <TextView android:id="@+id/tv_bp_display"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--/--"
                    android:textColor="@color/colorText"
                    android:textSize="48sp" android:textStyle="bold"
                    android:letterSpacing="-0.02"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="4dp">
                    <TextView android:id="@+id/tv_bp_status"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="-- / -- mmHg"
                        android:textColor="@color/colorMuted" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_bp_category"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Awaiting"
                        android:textColor="@color/colorAccent"
                        android:textSize="12sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2x3 Metric Grid -->
        <GridLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:columnCount="2" android:rowCount="3"
            android:layout_marginBottom="10dp">

            <com.google.android.material.card.MaterialCardView android:id="@+id/tile_hr"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp"
                app:strokeWidth="1dp" app:strokeColor="@color/colorBorder">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tv_hr" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="26sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="bpm" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="❤️ Heart Rate" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:id="@+id/tile_hrv"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp"
                app:strokeWidth="1dp" app:strokeColor="@color/colorBorder">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tv_hrv" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="26sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ms" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📊 HRV" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:id="@+id/tile_spo2"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp"
                app:strokeWidth="1dp" app:strokeColor="@color/colorBorder">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tv_spo2" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="26sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="%" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🫁 SpO₂" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:id="@+id/tile_temp"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp"
                app:strokeWidth="1dp" app:strokeColor="@color/colorBorder">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tv_temp" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="26sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="°F" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌡️ Temp" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:id="@+id/tile_rr"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp"
                app:strokeWidth="1dp" app:strokeColor="@color/colorBorder">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tv_rr" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="26sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="br/min" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌬️ Resp." android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:id="@+id/tile_stress"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp"
                app:strokeWidth="1dp" app:strokeColor="@color/colorBorder">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:id="@+id/tv_stress" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="26sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="score" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🧠 Stress" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- Steps / Calories / Sleep row -->
        <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:columnCount="3" android:layout_marginBottom="10dp">

            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp"
                app:strokeWidth="1dp" app:strokeColor="@color/colorBorder">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="10dp" android:gravity="center">
                    <TextView android:id="@+id/tv_steps" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👟 Steps" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp"
                app:strokeWidth="1dp" app:strokeColor="@color/colorBorder">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="10dp" android:gravity="center">
                    <TextView android:id="@+id/tv_calories" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔥 kcal" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="10dp"
                app:strokeWidth="1dp" app:strokeColor="@color/colorBorder">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="10dp" android:gravity="center">
                    <TextView android:id="@+id/tv_sleep" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textColor="@color/colorText" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💤 Sleep" android:textColor="@color/colorMuted" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

        <!-- Detail card -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="12dp"
            app:strokeWidth="1dp" app:strokeColor="@color/colorBorder">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="AUTONOMIC DETAIL"
                    android:textColor="@color/colorMuted" android:textSize="11sp"
                    android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:paddingVertical="4dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Resting HR"
                                android:textColor="@color/colorMuted" android:textSize="12sp"/>
                            <TextView android:id="@+id/tv_resting_hr" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="-- bpm"
                                android:textColor="@color/colorText" android:textSize="12sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:paddingVertical="4dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Peak HR"
                                android:textColor="@color/colorMuted" android:textSize="12sp"/>
                            <TextView android:id="@+id/tv_peak_hr" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="-- bpm"
                                android:textColor="@color/colorText" android:textSize="12sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:paddingVertical="4dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="HRV rMSSD"
                                android:textColor="@color/colorMuted" android:textSize="12sp"/>
                            <TextView android:id="@+id/tv_rmssd" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="-- ms"
                                android:textColor="@color/colorText" android:textSize="12sp"/>
                        </LinearLayout>
                    </LinearLayout>
                    <View android:layout_width="1dp" android:layout_height="match_parent"
                        android:background="@color/colorBorder" android:layout_marginHorizontal="10dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:paddingVertical="4dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Skin Temp Δ"
                                android:textColor="@color/colorMuted" android:textSize="12sp"/>
                            <TextView android:id="@+id/tv_skin_delta" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--°F"
                                android:textColor="@color/colorText" android:textSize="12sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:paddingVertical="4dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Activity"
                                android:textColor="@color/colorMuted" android:textSize="12sp"/>
                            <TextView android:id="@+id/tv_activity" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--"
                                android:textColor="@color/colorText" android:textSize="12sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:paddingVertical="4dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Blood O₂"
                                android:textColor="@color/colorMuted" android:textSize="12sp"/>
                            <TextView android:id="@+id/tv_spo2b" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="--%"
                                android:textColor="@color/colorText" android:textSize="12sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
